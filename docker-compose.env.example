# Docker Compose Environment Variables
# Copy this file to docker-compose.env and update the values

# MongoDB Configuration
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=your_mongo_admin_password
MONGO_INITDB_DATABASE=smsproject

# Application Database User
MONGO_APP_USERNAME=smsuser
MONGO_APP_PASSWORD=your_app_database_password

# Backend Configuration
BACKEND_PORT=5000
BACKEND_SECRET_KEY=your_backend_secret_key
BACKEND_JWT_SECRET=your_jwt_secret_key

# Frontend Configuration
FRONTEND_PORT=3000

# Redis Configuration (for caching)
REDIS_PASSWORD=your_redis_password

# Network Configuration
NETWORK_NAME=sms_network

# Volume Configuration
MONGO_DATA_PATH=./data/mongodb
REDIS_DATA_PATH=./data/redis
LOGS_PATH=./logs
UPLOADS_PATH=./uploads

# SSL Configuration (for production)
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# Backup Configuration
BACKUP_PATH=./backups
BACKUP_SCHEDULE=0 2 * * *

# AI Configuration
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-8b-8192

# Monitoring
ENABLE_MONITORING=false
GRAFANA_ADMIN_PASSWORD=your_grafana_password