# API Configuration
REACT_APP_BASE_URL=http://localhost:5000
REACT_APP_API_VERSION=v1

# Environment
REACT_APP_ENV=development

# App Configuration
REACT_APP_NAME=School Management System
REACT_APP_VERSION=1.0.0
REACT_APP_DESCRIPTION=Comprehensive School Management Platform

# Authentication
REACT_APP_JWT_STORAGE_KEY=sms_auth_token
REACT_APP_SESSION_TIMEOUT=3600000

# Features Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_DARK_MODE=true
REACT_APP_ENABLE_OFFLINE_MODE=false

# Third-party Services
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
REACT_APP_FIREBASE_API_KEY=your_firebase_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id

# Analytics
REACT_APP_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
REACT_APP_MIXPANEL_TOKEN=your_mixpanel_token

# Error Tracking
REACT_APP_SENTRY_DSN=your_sentry_dsn

# File Upload
REACT_APP_MAX_FILE_SIZE=10485760
REACT_APP_ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.pdf,.doc,.docx

# UI Configuration
REACT_APP_THEME_PRIMARY_COLOR=#1976d2
REACT_APP_THEME_SECONDARY_COLOR=#dc004e
REACT_APP_DEFAULT_LANGUAGE=en
REACT_APP_SUPPORTED_LANGUAGES=en,es,fr,de

# Performance
REACT_APP_ENABLE_SERVICE_WORKER=true
REACT_APP_CACHE_DURATION=300000

# Development Tools
REACT_APP_ENABLE_REDUX_DEVTOOLS=true
REACT_APP_ENABLE_WHY_DID_YOU_RENDER=false

# Notifications
REACT_APP_NOTIFICATION_TIMEOUT=5000
REACT_APP_ENABLE_PUSH_NOTIFICATIONS=true

# Charts and Visualization
REACT_APP_CHART_ANIMATION_DURATION=1000
REACT_APP_DEFAULT_CHART_COLORS=#8884d8,#82ca9d,#ffc658,#ff7300

# Security
REACT_APP_ENABLE_CSP=true
REACT_APP_ALLOWED_HOSTS=localhost,127.0.0.1

# PWA Configuration
REACT_APP_PWA_NAME=SMS
REACT_APP_PWA_SHORT_NAME=SchoolMS
REACT_APP_PWA_THEME_COLOR=#1976d2
REACT_APP_PWA_BACKGROUND_COLOR=#ffffff