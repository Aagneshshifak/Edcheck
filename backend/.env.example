# Database Configuration
MONGO_URL=mongodb://127.0.0.1:27017/smsproject
# For MongoDB Atlas (cloud):
# MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/smsproject?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development

# Security
SECRET_KEY=your_secret_key_here_make_it_long_and_random
JWT_SECRET=your_jwt_secret_key_for_authentication
JWT_EXPIRE=7d

# Email Configuration (OPTIONAL - for notifications)
# You can skip this section and use placeholder values
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@yourschool.com

# SMS Configuration (optional)
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=SCHOOL

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# AI/ML Services (for future AI features)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-8b-8192
GROQ_BASE_URL=https://api.groq.com/openai/v1
ANALYTICS_SERVICE_URL=http://localhost:8000

# Alternative AI Models Configuration
GROQ_MODELS_AVAILABLE=llama3-8b-8192,llama3-70b-8192,mixtral-8x7b-32768,gemma-7b-it
GROQ_DEFAULT_TEMPERATURE=0.7
GROQ_MAX_TOKENS=1024
GROQ_TIMEOUT=30000

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# CORS Configuration
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your_session_secret_key
SESSION_TIMEOUT=3600000

# Third-party Integrations
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30